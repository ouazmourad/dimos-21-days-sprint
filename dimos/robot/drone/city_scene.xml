<mujoco model="Skydio X2 City">
  <compiler autolimits="true" assetdir="assets"/>

  <option timestep="0.01" density="1.225" viscosity="1.8e-5"/>

  <default>
    <!-- City scenery: visual only, no collision with drone -->
    <default class="scenery">
      <geom contype="0" conaffinity="0"/>
    </default>
    <default class="x2">
      <geom mass="0"/>
      <motor ctrlrange="0 13"/>
      <mesh scale="0.01 0.01 0.01"/>
      <default class="visual">
        <geom group="2" type="mesh" contype="0" conaffinity="0"/>
      </default>
      <default class="collision">
        <geom group="3" type="box"/>
        <default class="rotor">
          <geom type="ellipsoid" size=".13 .13 .01"/>
        </default>
      </default>
      <site group="5"/>
    </default>
  </default>

  <statistic center="0 0 5" extent="30" meansize="0.5"/>

  <visual>
    <headlight diffuse="0.5 0.5 0.5" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-20" elevation="-20" ellipsoidinertia="true"/>
    <map znear="0.01" zfar="200"/>
  </visual>

  <asset>
    <!-- Drone mesh + texture -->
    <texture type="2d" name="x2_tex" file="X2_lowpoly_texture_SpinningProps_1024.png"/>
    <material name="phong3SG" texture="x2_tex"/>
    <material name="invisible" rgba="0 0 0 0"/>
    <mesh class="x2" file="X2_lowpoly.obj"/>

    <!-- Sky -->
    <texture type="skybox" builtin="gradient" rgb1="0.4 0.6 0.8" rgb2="0.05 0.1 0.2"
      width="512" height="3072"/>

    <!-- Road texture -->
    <texture type="2d" name="road_tex" builtin="flat" rgb1="0.25 0.25 0.25"
      width="64" height="64"/>
    <material name="road" texture="road_tex" reflectance="0.05"/>

    <!-- Sidewalk -->
    <texture type="2d" name="sidewalk_tex" builtin="flat" rgb1="0.55 0.55 0.5"
      width="64" height="64"/>
    <material name="sidewalk" texture="sidewalk_tex"/>

    <!-- Grass/park -->
    <texture type="2d" name="grass_tex" builtin="flat" rgb1="0.2 0.45 0.15"
      width="64" height="64"/>
    <material name="grass" texture="grass_tex"/>

    <!-- Ground (asphalt) -->
    <texture type="2d" name="ground_tex" builtin="checker" mark="edge"
      rgb1="0.18 0.18 0.18" rgb2="0.15 0.15 0.15"
      markrgb="0.3 0.3 0.1" width="300" height="300"/>
    <material name="ground" texture="ground_tex" texuniform="true" texrepeat="20 20" reflectance="0.02"/>

    <!-- Building materials -->
    <material name="glass" rgba="0.5 0.65 0.8 0.6" reflectance="0.5"/>
    <material name="concrete" rgba="0.65 0.63 0.6 1" reflectance="0.05"/>
    <material name="brick" rgba="0.6 0.35 0.25 1" reflectance="0.03"/>
    <material name="steel" rgba="0.45 0.48 0.52 1" reflectance="0.3"/>
    <material name="dark_glass" rgba="0.2 0.25 0.35 0.7" reflectance="0.6"/>
    <material name="white_concrete" rgba="0.85 0.83 0.8 1" reflectance="0.1"/>
    <material name="red_brick" rgba="0.55 0.2 0.15 1" reflectance="0.03"/>
    <material name="yellow_paint" rgba="0.9 0.8 0.1 1"/>
    <material name="white_paint" rgba="0.95 0.95 0.95 1"/>

    <!-- Car materials -->
    <material name="car_red" rgba="0.8 0.15 0.1 1" reflectance="0.3"/>
    <material name="car_blue" rgba="0.1 0.2 0.7 1" reflectance="0.3"/>
    <material name="car_white" rgba="0.9 0.9 0.88 1" reflectance="0.25"/>
    <material name="car_black" rgba="0.1 0.1 0.12 1" reflectance="0.35"/>
    <material name="car_silver" rgba="0.7 0.72 0.73 1" reflectance="0.4"/>
    <material name="car_yellow" rgba="0.9 0.75 0.05 1" reflectance="0.3"/>
    <material name="tire" rgba="0.15 0.15 0.15 1" reflectance="0.02"/>
    <material name="window" rgba="0.2 0.25 0.35 0.8" reflectance="0.5"/>
  </asset>

  <worldbody>
    <!-- Lights -->
    <light pos="0 0 30" dir="0 0 -1" directional="true" diffuse="0.8 0.8 0.75" castshadow="true"/>
    <light pos="-20 20 25" dir="0.5 -0.5 -1" diffuse="0.3 0.3 0.35"/>

    <!-- Ground plane -->
    <geom name="floor" size="50 50 0.1" type="plane" material="ground"/>

    <!-- ═══════════════ ROADS ═══════════════ -->
    <!-- Main road (runs along X axis) -->
    <geom class="scenery" type="box" size="50 3.5 0.005" pos="0 0 0.005" material="road"/>
    <!-- Center line -->
    <geom class="scenery" type="box" size="50 0.05 0.006" pos="0 0 0.006" material="yellow_paint"/>

    <!-- Cross street (runs along X axis) -->
    <geom class="scenery" type="box" size="3.5 50 0.005" pos="15 0 0.005" material="road"/>
    <geom class="scenery" type="box" size="0.05 50 0.006" pos="15 0 0.006" material="yellow_paint"/>

    <!-- Second cross street -->
    <geom class="scenery" type="box" size="3.5 50 0.005" pos="-15 0 0.005" material="road"/>
    <geom class="scenery" type="box" size="0.05 50 0.006" pos="-15 0 0.006" material="yellow_paint"/>

    <!-- Sidewalks along main road -->
    <geom class="scenery" type="box" size="50 0.8 0.06" pos="0 4.3 0.06" material="sidewalk"/>
    <geom class="scenery" type="box" size="50 0.8 0.06" pos="0 -4.3 0.06" material="sidewalk"/>

    <!-- ═══════════════ BLOCK 1: Downtown (right of main road) ═══════════════ -->

    <!-- Tall office tower -->
    <geom class="scenery" type="box" size="3 4 10" pos="0 10 10" material="dark_glass"/>
    <geom class="scenery" type="box" size="3.1 4.1 0.15" pos="0 10 20" material="steel"/> <!-- roof edge -->

    <!-- Medium concrete building -->
    <geom class="scenery" type="box" size="4 3 6" pos="-9 10 6" material="concrete"/>
    <geom class="scenery" type="box" size="3.5 2.5 0.5" pos="-9 10 12" material="concrete"/> <!-- rooftop structure -->

    <!-- Red brick apartment -->
    <geom class="scenery" type="box" size="3 3.5 4" pos="9 10 4" material="red_brick"/>
    <geom class="scenery" type="box" size="3.1 3.6 0.1" pos="9 10 8" material="brick"/> <!-- cornice -->

    <!-- Small shop row -->
    <geom class="scenery" type="box" size="2 2.5 2.5" pos="-8 6 2.5" material="white_concrete"/>
    <geom class="scenery" type="box" size="2 2.5 2.5" pos="-4 6 2.5" material="brick"/>

    <!-- ═══════════════ BLOCK 2: Left of main road ═══════════════ -->

    <!-- Glass skyscraper -->
    <geom class="scenery" type="box" size="3.5 3 14" pos="-2 -10 14" material="glass"/>
    <geom class="scenery" type="box" size="3 2.5 2" pos="-2 -10 30" material="steel"/> <!-- antenna structure -->

    <!-- Parking garage -->
    <geom class="scenery" type="box" size="4 5 3" pos="10 -11 3" material="concrete"/>
    <geom class="scenery" type="box" size="3.8 4.8 0.1" pos="10 -11 6" material="concrete"/> <!-- top level -->

    <!-- Row houses -->
    <geom class="scenery" type="box" size="1.5 2.5 3" pos="-10 -7 3" material="brick"/>
    <geom class="scenery" type="box" size="1.5 2.5 3.5" pos="-13 -7 3.5" material="red_brick"/>
    <geom class="scenery" type="box" size="1.5 2.5 2.8" pos="-16 -7 2.8" material="white_concrete"/>

    <!-- Modern office -->
    <geom class="scenery" type="box" size="3 3.5 7" pos="-12 -10 7" material="steel"/>

    <!-- ═══════════════ BLOCK 3: Far buildings ═══════════════ -->

    <!-- Distant skyline buildings -->
    <geom class="scenery" type="box" size="3 3 18" pos="5 22 18" material="dark_glass"/>
    <geom class="scenery" type="box" size="3 4 12" pos="-5 22 12" material="steel"/>
    <geom class="scenery" type="box" size="4 3 8" pos="15 20 8" material="concrete"/>
    <geom class="scenery" type="box" size="3 5 15" pos="0 -22 15" material="glass"/>
    <geom class="scenery" type="box" size="5 3 10" pos="-15 -20 10" material="dark_glass"/>
    <geom class="scenery" type="box" size="3 4 7" pos="-18 18 7" material="brick"/>

    <!-- ═══════════════ PARK ═══════════════ -->
    <geom class="scenery" type="box" size="4 5 0.01" pos="15 18 0.01" material="grass"/>
    <!-- Trees (simple cylinders + spheres) -->
    <geom class="scenery" type="cylinder" size="0.15 1.2" pos="14 16 1.2" material="brick"/>
    <geom class="scenery" type="sphere" size="0.8" pos="14 16 2.8" rgba="0.15 0.5 0.12 1"/>
    <geom class="scenery" type="cylinder" size="0.12 1.0" pos="16 19 1.0" material="brick"/>
    <geom class="scenery" type="sphere" size="0.7" pos="16 19 2.3" rgba="0.2 0.55 0.15 1"/>
    <geom class="scenery" type="cylinder" size="0.15 1.3" pos="17 17 1.3" material="brick"/>
    <geom class="scenery" type="sphere" size="0.9" pos="17 17 3.0" rgba="0.12 0.45 0.1 1"/>

    <!-- ═══════════════ STREET LIGHTS ═══════════════ -->
    <geom class="scenery" type="cylinder" size="0.06 3" pos="5 4.3 3" material="steel"/>
    <geom class="scenery" type="box" size="0.05 0.5 0.05" pos="5 3.8 6" material="steel"/>
    <geom class="scenery" type="cylinder" size="0.06 3" pos="-5 4.3 3" material="steel"/>
    <geom class="scenery" type="box" size="0.05 0.5 0.05" pos="-5 3.8 6" material="steel"/>
    <geom class="scenery" type="cylinder" size="0.06 3" pos="5 -4.3 3" material="steel"/>
    <geom class="scenery" type="box" size="0.05 0.5 0.05" pos="5 -3.8 6" material="steel"/>
    <geom class="scenery" type="cylinder" size="0.06 3" pos="-5 -4.3 3" material="steel"/>
    <geom class="scenery" type="box" size="0.05 0.5 0.05" pos="-5 -3.8 6" material="steel"/>

    <!-- ═══════════════ CARS ═══════════════ -->

    <!-- Car 1: Red sedan on main road, heading north -->
    <body name="car1" pos="3 1.5 0.25">
      <geom class="scenery" type="box" size="0.45 0.9 0.25" material="car_red"/>   <!-- body -->
      <geom class="scenery" type="box" size="0.42 0.5 0.22" pos="0 -0.05 0.35" material="window"/> <!-- cabin -->
      <geom class="scenery" type="cylinder" size="0.18 0.08" pos="0.5 0.55 -0.12" euler="90 0 0" material="tire"/>
      <geom class="scenery" type="cylinder" size="0.18 0.08" pos="-0.5 0.55 -0.12" euler="90 0 0" material="tire"/>
      <geom class="scenery" type="cylinder" size="0.18 0.08" pos="0.5 -0.55 -0.12" euler="90 0 0" material="tire"/>
      <geom class="scenery" type="cylinder" size="0.18 0.08" pos="-0.5 -0.55 -0.12" euler="90 0 0" material="tire"/>
    </body>

    <!-- Car 2: Blue SUV, heading south -->
    <body name="car2" pos="-6 -1.5 0.3">
      <geom class="scenery" type="box" size="0.5 1.1 0.3" material="car_blue"/>
      <geom class="scenery" type="box" size="0.47 0.65 0.28" pos="0 -0.1 0.42" material="window"/>
      <geom class="scenery" type="cylinder" size="0.2 0.09" pos="0.55 0.65 -0.15" euler="90 0 0" material="tire"/>
      <geom class="scenery" type="cylinder" size="0.2 0.09" pos="-0.55 0.65 -0.15" euler="90 0 0" material="tire"/>
      <geom class="scenery" type="cylinder" size="0.2 0.09" pos="0.55 -0.65 -0.15" euler="90 0 0" material="tire"/>
      <geom class="scenery" type="cylinder" size="0.2 0.09" pos="-0.55 -0.65 -0.15" euler="90 0 0" material="tire"/>
    </body>

    <!-- Car 3: White sedan on cross street -->
    <body name="car3" pos="16 8 0.25" euler="0 0 90">
      <geom class="scenery" type="box" size="0.45 0.9 0.25" material="car_white"/>
      <geom class="scenery" type="box" size="0.42 0.5 0.22" pos="0 -0.05 0.35" material="window"/>
      <geom class="scenery" type="cylinder" size="0.18 0.08" pos="0.5 0.55 -0.12" euler="90 0 0" material="tire"/>
      <geom class="scenery" type="cylinder" size="0.18 0.08" pos="-0.5 0.55 -0.12" euler="90 0 0" material="tire"/>
      <geom class="scenery" type="cylinder" size="0.18 0.08" pos="0.5 -0.55 -0.12" euler="90 0 0" material="tire"/>
      <geom class="scenery" type="cylinder" size="0.18 0.08" pos="-0.5 -0.55 -0.12" euler="90 0 0" material="tire"/>
    </body>

    <!-- Car 4: Black SUV parked -->
    <body name="car4" pos="-2 5.5 0.3">
      <geom class="scenery" type="box" size="0.5 1.1 0.3" material="car_black"/>
      <geom class="scenery" type="box" size="0.47 0.65 0.28" pos="0 -0.1 0.42" material="window"/>
      <geom class="scenery" type="cylinder" size="0.2 0.09" pos="0.55 0.65 -0.15" euler="90 0 0" material="tire"/>
      <geom class="scenery" type="cylinder" size="0.2 0.09" pos="-0.55 0.65 -0.15" euler="90 0 0" material="tire"/>
      <geom class="scenery" type="cylinder" size="0.2 0.09" pos="0.55 -0.65 -0.15" euler="90 0 0" material="tire"/>
      <geom class="scenery" type="cylinder" size="0.2 0.09" pos="-0.55 -0.65 -0.15" euler="90 0 0" material="tire"/>
    </body>

    <!-- Car 5: Silver sedan -->
    <body name="car5" pos="12 -1.5 0.25">
      <geom class="scenery" type="box" size="0.45 0.9 0.25" material="car_silver"/>
      <geom class="scenery" type="box" size="0.42 0.5 0.22" pos="0 -0.05 0.35" material="window"/>
      <geom class="scenery" type="cylinder" size="0.18 0.08" pos="0.5 0.55 -0.12" euler="90 0 0" material="tire"/>
      <geom class="scenery" type="cylinder" size="0.18 0.08" pos="-0.5 0.55 -0.12" euler="90 0 0" material="tire"/>
      <geom class="scenery" type="cylinder" size="0.18 0.08" pos="0.5 -0.55 -0.12" euler="90 0 0" material="tire"/>
      <geom class="scenery" type="cylinder" size="0.18 0.08" pos="-0.5 -0.55 -0.12" euler="90 0 0" material="tire"/>
    </body>

    <!-- Car 6: Yellow taxi on cross street -->
    <body name="car6" pos="-14.5 -12 0.25" euler="0 0 90">
      <geom class="scenery" type="box" size="0.45 0.95 0.25" material="car_yellow"/>
      <geom class="scenery" type="box" size="0.42 0.5 0.22" pos="0 -0.05 0.35" material="window"/>
      <geom class="scenery" type="cylinder" size="0.18 0.08" pos="0.5 0.55 -0.12" euler="90 0 0" material="tire"/>
      <geom class="scenery" type="cylinder" size="0.18 0.08" pos="-0.5 0.55 -0.12" euler="90 0 0" material="tire"/>
      <geom class="scenery" type="cylinder" size="0.18 0.08" pos="0.5 -0.55 -0.12" euler="90 0 0" material="tire"/>
      <geom class="scenery" type="cylinder" size="0.18 0.08" pos="-0.5 -0.55 -0.12" euler="90 0 0" material="tire"/>
    </body>

    <!-- Car 7: Red car parked on side street -->
    <body name="car7" pos="8 5.5 0.25" euler="0 0 15">
      <geom class="scenery" type="box" size="0.45 0.9 0.25" material="car_red"/>
      <geom class="scenery" type="box" size="0.42 0.5 0.22" pos="0 -0.05 0.35" material="window"/>
      <geom class="scenery" type="cylinder" size="0.18 0.08" pos="0.5 0.55 -0.12" euler="90 0 0" material="tire"/>
      <geom class="scenery" type="cylinder" size="0.18 0.08" pos="-0.5 0.55 -0.12" euler="90 0 0" material="tire"/>
      <geom class="scenery" type="cylinder" size="0.18 0.08" pos="0.5 -0.55 -0.12" euler="90 0 0" material="tire"/>
      <geom class="scenery" type="cylinder" size="0.18 0.08" pos="-0.5 -0.55 -0.12" euler="90 0 0" material="tire"/>
    </body>

    <!-- ═══════════════ DRONE (starts at street level) ═══════════════ -->
    <body name="x2" pos="0 -3 0.1" childclass="x2">
      <freejoint/>
      <camera name="track" pos="-2 0 1.5" xyaxes="0 -1 0 0.3 0 1" mode="trackcom"/>
      <camera name="fpv" pos="0.15 0 0.05" xyaxes="0 -1 0 0 0 1" fovy="90"/>
      <site name="imu" pos="0 0 .02"/>
      <geom material="phong3SG" mesh="X2_lowpoly" class="visual" quat="0 0 1 1"/>
      <geom class="collision" size=".06 .027 .02" pos=".04 0 .02"/>
      <geom class="collision" size=".06 .027 .02" pos=".04 0 .06"/>
      <geom class="collision" size=".05 .027 .02" pos="-.07 0 .065"/>
      <geom class="collision" size=".023 .017 .01" pos="-.137 .008 .065" quat="1 0 0 1"/>
      <geom name="rotor1" class="rotor" pos="-.14 -.18 .05" mass=".25"/>
      <geom name="rotor2" class="rotor" pos="-.14 .18 .05" mass=".25"/>
      <geom name="rotor3" class="rotor" pos=".14 .18 .08" mass=".25"/>
      <geom name="rotor4" class="rotor" pos=".14 -.18 .08" mass=".25"/>
      <geom size=".16 .04 .02" pos="0 0 0.02" type="ellipsoid" mass=".325" class="visual" material="invisible"/>
      <site name="thrust1" pos="-.14 -.18 .05"/>
      <site name="thrust2" pos="-.14 .18 .05"/>
      <site name="thrust3" pos=".14 .18 .08"/>
      <site name="thrust4" pos=".14 -.18 .08"/>
    </body>

  </worldbody>

  <actuator>
    <motor class="x2" name="thrust1" site="thrust1" gear="0 0 1 0 0 -.0201"/>
    <motor class="x2" name="thrust2" site="thrust2" gear="0 0 1 0 0  .0201"/>
    <motor class="x2" name="thrust3" site="thrust3" gear="0 0 1 0 0  .0201"/>
    <motor class="x2" name="thrust4" site="thrust4" gear="0 0 1 0 0 -.0201"/>
  </actuator>

  <sensor>
    <gyro name="body_gyro" site="imu"/>
    <accelerometer name="body_linacc" site="imu"/>
    <framequat name="body_quat" objtype="site" objname="imu"/>
  </sensor>

  <keyframe>
    <key name="hover" qpos="0 -3 3 0.707 0 0 0.707" ctrl="3.2495625 3.2495625 3.2495625 3.2495625"/>
  </keyframe>
</mujoco>
